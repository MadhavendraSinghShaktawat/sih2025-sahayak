    {
      "id": "0880f91f-0499-4ee5-a813-398156eeb3b4",
      "name": "Format Image Data URL",
      "type": "n8n-nodes-base.code",
      "position": [
        512,
        2048
      ],
      "parameters": {
        "jsCode": "// Use the image_url directly from webhook input\nconst items = $input.all();\nconst updatedItems = items.map((item) => {\n  const imageUrl = item?.json?.image_url;\n  return { url: imageUrl };\n});\nreturn updatedItems;\n"
      },
      "typeVersion": 2
    },
