      "name": "Process Webhook Input",
      "type": "n8n-nodes-base.function",
      "position": [
        112,
        2048
      ],
      "parameters": {
        "functionCode": "// Process webhook input - expect image_url and prompt\nconst input = $input.first().json;\n\n// Return the input data for processing\nreturn {\n  image_url: input.image_url || input.file_url,\n  prompt: input.prompt || input.context || input.caption\n};"
      },
      "typeVersion": 1
    },
    {
      "id": "c08670f8-81f0-41b9-ac7c-bc30847e5fba",
